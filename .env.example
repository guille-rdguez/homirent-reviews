# Supabase
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=pega_aqui_tu_service_role_key
# Opcional solo para pruebas locales o transicion:
# SUPABASE_DASHBOARD_KEY=pega_aqui_un_key_con_lectura_para_dashboard

# Cloudbeds sync
# API key property-level o group-level con acceso a reservas
CLOUDBEDS_API_KEY=pega_aqui_tu_cloudbeds_api_key
# Opcional
# CLOUDBEDS_API_BASE_URL=https://api.cloudbeds.com/api/v1.3
# CLOUDBEDS_PROPERTY_IDS=200001,200002
# CLOUDBEDS_GROUP_ACCOUNT_ID=tu_group_account_id
# CLOUDBEDS_SOURCE_ACCOUNT_ID=uuid_del_source_account_cloudbeds_en_supabase
# CLOUDBEDS_DEFAULT_SYNC_WINDOW_DAYS=14
# Recomendado para cron o llamadas internas sin sesión de dashboard
# CLOUDBEDS_SYNC_SECRET=secreto-interno-para-cloudbeds-sync

# Inbound email / review parsing
# Recomendado para webhooks o integraciones automáticas sin sesión del dashboard
# INBOUND_EMAIL_SECRET=secreto-interno-para-inbound-email
# INBOUND_AUTO_MATCH_THRESHOLD=0.85

# Dashboard interno
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=cambia-esta-clave
DASHBOARD_SESSION_SECRET=cambia-este-secreto-largo-y-unico
DASHBOARD_SESSION_HOURS=12
